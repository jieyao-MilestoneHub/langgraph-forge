"""Specialist declarations for the custom pattern.

The custom pattern is an escape hatch: you compose nodes and edges
directly in graph.py. This file ships two ReAct workers (a planner
and an executor) as a sensible default the build() callback in
graph.py can wire sequentially. Replace either factory -- or add
deterministic Python nodes alongside them -- to fit your topology.
"""

from __future__ import annotations

from langchain_core.language_models import BaseChatModel
from langgraph.graph.state import CompiledStateGraph
from langgraph.prebuilt import create_react_agent

from langgraph_forge import get_model

from {{ package_name }}.providers import specialist_model_spec

PLANNER_PROMPT = (
    "You are a planner. Break the user's request into a numbered "
    "sequence of concrete, actionable steps. Do not execute the "
    "steps -- just produce the plan."
)

EXECUTOR_PROMPT = (
    "You are an executor. Read the plan from the previous message "
    "and carry out each step in order, calling tools when needed. "
    "Return a final summary of what you accomplished."
)


def _model() -> BaseChatModel:
    return get_model(specialist_model_spec())


def make_planner() -> CompiledStateGraph:
    return create_react_agent(
        model=_model(),
        tools=[],
        prompt=PLANNER_PROMPT,
        name="planner",
    )


def make_executor() -> CompiledStateGraph:
    return create_react_agent(
        model=_model(),
        tools=[],
        prompt=EXECUTOR_PROMPT,
        name="executor",
    )
