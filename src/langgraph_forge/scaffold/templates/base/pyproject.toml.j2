[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[project]
name = "{{ project_name }}"
version = "0.1.0"
description = "LangGraph agent scaffolded with langgraph-forge."
requires-python = ">=3.11"
dependencies = [
{%- if checkpointer in ("sqlite", "postgres") %}
  "langgraph-forge[{{ checkpointer }}]>=0.1.0a1",
{%- else %}
  "langgraph-forge>=0.1.0a1",
{%- endif %}
]

[project.optional-dependencies]
dev = [
  "pytest>=8",
  "pytest-asyncio>=0.23",
]

[tool.hatch.build.targets.wheel]
packages = ["src/{{ package_name }}"]

[tool.pytest.ini_options]
testpaths = ["tests"]
asyncio_mode = "auto"
