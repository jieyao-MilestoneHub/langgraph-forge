"""Azure OpenAI LLM provider configuration for {{ project_name }}."""

from __future__ import annotations

import os

from langchain_core.language_models import BaseChatModel

from langgraph_forge import ModelSpec, get_model

# Azure OpenAI uses deployment names, not model names; set via env.
SUPERVISOR_MODEL = os.environ.get("AZURE_OPENAI_SUPERVISOR_DEPLOYMENT", "gpt-4o")
SPECIALIST_MODEL = os.environ.get("AZURE_OPENAI_SPECIALIST_DEPLOYMENT", "gpt-4o-mini")


def supervisor_model_spec() -> ModelSpec:
    return ModelSpec(model=SUPERVISOR_MODEL, provider="azure_openai")


def specialist_model_spec() -> ModelSpec:
    return ModelSpec(model=SPECIALIST_MODEL, provider="azure_openai")


def get_supervisor_model() -> BaseChatModel:
    return get_model(supervisor_model_spec())
