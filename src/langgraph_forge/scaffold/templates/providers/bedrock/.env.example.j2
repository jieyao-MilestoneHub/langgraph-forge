# AWS credentials -- any mechanism boto3 accepts works:
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-west-2
# Or use AWS_PROFILE / IAM role attached to the runtime.
{% if checkpointer in ("sqlite", "postgres") %}
# Persistence backend ({{ checkpointer }}). For sqlite use a file path
# (e.g. checkpoints.db); for postgres use a libpq connection string
# (e.g. postgresql://user:pass@host:5432/dbname).
LANGGRAPH_FORGE_CHECKPOINTER_CONN_STRING=
{% endif %}
